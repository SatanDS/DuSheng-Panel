[Unit]
Description=DuSheng Panel node agent
Documentation=https://github.com/SatanDS/DuSheng-Panel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=dusheng-agent
Group=dusheng-agent
WorkingDirectory=/opt/dusheng-agent
Environment=DUSHENG_DATA_DIR=/var/lib/dusheng-agent
Environment=DUSHENG_GOST_PATH=/usr/local/bin/gost
Environment=DUSHENG_GOST_BIN=/usr/local/bin/gost
Environment=DUSHENG_DPI_ADDR=unix:/run/dusheng-dpi/dpi.sock
EnvironmentFile=-/etc/dusheng/agent.env
ExecStart=/opt/dusheng-agent/dusheng-agent -base-url ${DUSHENG_API_URL} -install-token ${DUSHENG_INSTALL_TOKEN} -data-dir ${DUSHENG_DATA_DIR} -gost-path ${DUSHENG_GOST_PATH} -dpi-addr ${DUSHENG_DPI_ADDR}
ExecStopPost=+/bin/bash /opt/dusheng-agent/uninstall-agent.sh
Restart=on-failure
RestartSec=3
LimitNOFILE=1048576
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/dusheng-agent /var/log/dusheng-agent /opt/dusheng-agent /etc/dusheng /etc/systemd/system

[Install]
WantedBy=multi-user.target
