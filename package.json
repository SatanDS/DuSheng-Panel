{
  "name": "dusheng-panel",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.2",
  "description": "DuSheng Panel monorepo: forwarding panel, API server, and Linux node agent.",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "test:go": "go test ./apps/api/... ./apps/agent/...",
    "build:api": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && go build -o dist/dusheng-api ./apps/api/cmd/api",
    "build:agent": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && go build -o dist/dusheng-agent ./apps/agent/cmd/agent"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
